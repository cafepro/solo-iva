<turbo-frame id="pending_badge">
  <% if count > 0 %>
    <%= link_to review_invoices_path, class: "relative inline-flex items-center", data: { turbo_frame: "_top" } do %>
      <span class="text-sm text-white/85 hover:text-brand-teal transition-colors">Subir facturas</span>
      <span class="ml-1 inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-red-500 rounded-full"><%= count %></span>
    <% end %>
  <% else %>
    <%= link_to "Subir facturas", review_invoices_path, class: "text-sm text-white/85 hover:text-brand-teal transition-colors", data: { turbo_frame: "_top" } %>
  <% end %>
</turbo-frame>
