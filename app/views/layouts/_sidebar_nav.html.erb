<%# Movimientos: cada listado + “Subir facturas” como subítem %>
<% nav_link = "flex items-center gap-2.5 rounded-md px-3 py-2 text-sm text-white/90 transition-colors hover:bg-white/10 hover:text-white" %>
<% icon_class = "h-5 w-5 shrink-0 text-white/55" %>

<div class="space-y-6">
  <div>
    <p class="mb-2 px-3 text-[10px] font-semibold uppercase tracking-wider text-white/45">Movimientos</p>
    <nav class="flex flex-col gap-3">
      <%# Emitidas: listado + subir %>
      <div class="flex flex-col gap-0.5">
        <%= link_to invoices_path(invoice_type: "emitida"), class: nav_link, data: { turbo_frame: "_top", action: "click->sidebar-nav#close" } do %>
          <svg class="<%= icon_class %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
          </svg>
          <span>Facturas emitidas</span>
        <% end %>
        <div class="ml-3 flex flex-col border-l border-white/20 pl-3">
          <%= render "layouts/pending_badge_for_type",
                invoice_type: "emitida",
                count:          pending_review_count_for(current_user, :emitida) %>
        </div>
      </div>

      <%# Recibidas: listado + subir %>
      <div class="flex flex-col gap-0.5">
        <%= link_to invoices_path(invoice_type: "recibida"), class: nav_link, data: { turbo_frame: "_top", action: "click->sidebar-nav#close" } do %>
          <svg class="<%= icon_class %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M2.25 13.5h3m-3 0v-6a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121.75 7.5v6m-16.5 0V9.75A2.25 2.25 0 016 7.5h12a2.25 2.25 0 012.25 2.25V13.5m-16.5 0h16.5M5.25 21h13.5a2.25 2.25 0 002.25-2.25V13.5m-18 4.5h18"/>
          </svg>
          <span>Facturas recibidas</span>
        <% end %>
        <div class="ml-3 flex flex-col border-l border-white/20 pl-3">
          <%= render "layouts/pending_badge_for_type",
                invoice_type: "recibida",
                count:          pending_review_count_for(current_user, :recibida) %>
        </div>
      </div>
    </nav>
  </div>

  <div>
    <p class="mb-2 px-3 text-[10px] font-semibold uppercase tracking-wider text-white/45">Catálogo</p>
    <nav class="flex flex-col gap-0.5">
      <%= link_to clients_path, class: nav_link, data: { turbo_frame: "_top", action: "click->sidebar-nav#close" } do %>
        <svg class="<%= icon_class %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
        </svg>
        <span>Clientes</span>
      <% end %>
      <%= link_to service_templates_path, class: nav_link, data: { turbo_frame: "_top", action: "click->sidebar-nav#close" } do %>
        <svg class="<%= icon_class %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/>
        </svg>
        <span>Plantillas</span>
      <% end %>
    </nav>
  </div>

  <div>
    <p class="mb-2 px-3 text-[10px] font-semibold uppercase tracking-wider text-white/45">Informes y obligaciones</p>
    <nav class="flex flex-col gap-0.5">
      <%= link_to modelo303_reports_path, class: nav_link, data: { turbo_frame: "_top", action: "click->sidebar-nav#close" } do %>
        <svg class="<%= icon_class %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
        </svg>
        <span>Modelo 303</span>
      <% end %>
    </nav>
  </div>

  <div>
    <p class="mb-2 px-3 text-[10px] font-semibold uppercase tracking-wider text-white/45">Cuenta y sistema</p>
    <nav class="flex flex-col gap-0.5">
      <%= link_to billing_profile_path, class: nav_link, data: { turbo_frame: "_top", action: "click->sidebar-nav#close" } do %>
        <svg class="<%= icon_class %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
        </svg>
        <span>Datos de facturación</span>
      <% end %>
      <%= link_to google_drive_settings_path, class: nav_link, data: { turbo_frame: "_top", action: "click->sidebar-nav#close" } do %>
        <svg class="<%= icon_class %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M2.25 15a4.5 4.5 0 004.5 4.5h9a4.5 4.5 0 004.5-4.5 4.5 4.5 0 00-.884-2.692 4.002 4.002 0 00-6.152-4.59 4.5 4.5 0 00-8.464 2.282A4.501 4.501 0 002.25 15z"/>
        </svg>
        <span>Google Drive</span>
      <% end %>
    </nav>
  </div>
</div>
