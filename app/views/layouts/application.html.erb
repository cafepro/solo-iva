<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "SoloIVA" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                navy: "#1D416E",
                "navy-dark": "#163558",
                muted: "#E8EEF5",
                teal: "#3DB2A4",
                "teal-dark": "#2f9d90",
                "teal-muted": "#E8F6F4",
                "teal-soft": "#d4f0ec"
              }
            }
          }
        }
      }
    </script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 min-h-screen antialiased">
    <% if user_signed_in? %>
      <div class="min-h-screen md:flex" data-controller="sidebar-nav">
        <div data-sidebar-nav-target="backdrop"
             data-action="click->sidebar-nav#close"
             class="fixed inset-0 z-40 hidden bg-black/40 md:hidden"
             aria-hidden="true"></div>

        <aside data-sidebar-nav-target="panel"
               class="fixed inset-y-0 left-0 z-50 flex w-64 -translate-x-full flex-col border-r border-white/10 bg-brand-navy shadow-xl transition-transform duration-200 ease-out md:static md:z-0 md:translate-x-0 md:shadow-none">
          <div class="flex h-14 shrink-0 items-center border-b border-white/10 px-4">
            <%= link_to dashboard_path,
                class: "flex items-center rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-teal focus-visible:ring-offset-2 focus-visible:ring-offset-brand-navy",
                data: { turbo_frame: "_top", action: "click->sidebar-nav#close" } do %>
              <%= image_tag "soloiva_logo.png", alt: "SoloIVA", class: "h-8 w-auto" %>
            <% end %>
          </div>
          <div class="flex-1 overflow-y-auto overscroll-contain px-2 py-4">
            <%= turbo_stream_from "pending_badge_#{current_user.id}_emitida" %>
            <%= turbo_stream_from "pending_badge_#{current_user.id}_recibida" %>
            <%= render "layouts/sidebar_nav" %>
          </div>
          <div class="shrink-0 space-y-2 border-t border-white/10 p-4">
            <p class="truncate text-xs text-white/60" title="<%= current_user.email %>"><%= current_user.email %></p>
            <%= link_to "Salir", destroy_user_session_path,
                data: { turbo_method: :delete, turbo_frame: "_top", action: "click->sidebar-nav#close" },
                class: "inline-block text-sm text-red-300 transition-colors hover:text-red-100" %>
          </div>
        </aside>

        <%# Cabecera de sección va en el DOM después de <main> para que exista content_for(:title); order-1 la sitúa arriba. %>
        <div class="flex min-h-screen min-w-0 flex-1 flex-col">
          <main class="order-2 flex-1 px-4 py-6 sm:px-8 md:py-8">
            <% if notice.present? %>
              <div class="mb-4 rounded border border-brand-teal/25 bg-brand-teal-muted px-4 py-2 text-sm text-brand-navy"><%= notice %></div>
            <% end %>
            <% if alert.present? %>
              <div class="mb-4 rounded bg-red-100 px-4 py-2 text-red-800"><%= alert %></div>
            <% end %>

            <%= yield %>
          </main>

          <%# Misma altura que la franja del logo (aside h-14) para alinear título y marca en escritorio. %>
          <header class="order-1 flex h-14 shrink-0 items-center gap-2 border-b border-gray-200 bg-white px-3 sm:px-6 md:px-8">
            <button type="button"
                    class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md text-brand-navy hover:bg-gray-100 md:hidden"
                    data-action="click->sidebar-nav#open"
                    aria-label="Abrir menú">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
            <h1 class="min-w-0 flex-1 truncate text-lg font-semibold leading-none text-brand-navy md:text-xl md:leading-none">
              <%= page_section_heading %>
            </h1>
          </header>
        </div>
      </div>
    <% else %>
      <main class="min-h-screen">
        <% if notice.present? %>
          <div class="mx-auto max-w-screen-2xl px-6 pt-6 sm:px-8">
            <div class="mb-4 rounded border border-brand-teal/25 bg-brand-teal-muted px-4 py-2 text-sm text-brand-navy"><%= notice %></div>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="mx-auto max-w-screen-2xl px-6 pt-6 sm:px-8">
            <div class="mb-4 rounded bg-red-100 px-4 py-2 text-red-800"><%= alert %></div>
          </div>
        <% end %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
