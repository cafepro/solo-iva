<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "SoloIVA" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script src="https://cdn.tailwindcss.com"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <% if user_signed_in? %>
      <nav class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <%= link_to dashboard_path, class: "flex items-center shrink-0 rounded-md hover:opacity-90 transition-opacity focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2" do %>
            <%= image_tag "soloiva_logo.png", alt: "SoloIVA", class: "h-8 w-auto sm:h-9" %>
          <% end %>
          <%= render "layouts/pending_badge", count: current_user.invoices.pending_review.count %>
          <%= link_to "Facturas emitidas", invoices_path(invoice_type: "emitida"), class: "text-sm text-gray-600 hover:text-blue-600" %>
          <%= link_to "Facturas recibidas", invoices_path(invoice_type: "recibida"), class: "text-sm text-gray-600 hover:text-blue-600" %>
          <%= link_to "Clientes", clients_path, class: "text-sm text-gray-600 hover:text-blue-600" %>
          <%= link_to "Plantillas", service_templates_path, class: "text-sm text-gray-600 hover:text-blue-600" %>
          <%= link_to "Facturación", billing_profile_path, class: "text-sm text-gray-600 hover:text-blue-600" %>
          <%= link_to "Modelo 303", modelo303_reports_path, class: "text-sm text-gray-600 hover:text-blue-600" %>
          <%= link_to "Google Drive", google_drive_settings_path, class: "text-sm text-gray-600 hover:text-blue-600" %>
        </div>
        <div class="flex items-center gap-4 text-sm text-gray-500">
          <span><%= current_user.email %></span>
          <%= link_to "Salir", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-red-500 hover:text-red-700" %>
        </div>
      </nav>
    <% end %>

    <main class="max-w-screen-2xl mx-auto w-full px-6 sm:px-8 py-8">
      <% if notice.present? %>
        <div class="mb-4 px-4 py-2 bg-green-100 text-green-800 rounded"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-4 px-4 py-2 bg-red-100 text-red-800 rounded"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
