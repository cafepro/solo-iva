<%# Enlaces secundarios Devise; estilos coherentes con sesión / registro. %>
<% link_class = "text-brand-teal hover:text-brand-teal-dark font-medium underline-offset-2 hover:underline" %>

<%- if controller_name != "sessions" %>
  <p><%= link_to "Iniciar sesión", new_session_path(resource_name), class: link_class %></p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != "registrations" %>
  <p><%= link_to "Crear cuenta", new_registration_path(resource_name), class: link_class %></p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
  <p><%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name), class: link_class %></p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != "confirmations" %>
  <p><%= link_to "¿No recibiste el correo de confirmación?", new_confirmation_path(resource_name), class: link_class %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
  <p><%= link_to "¿No recibiste las instrucciones de desbloqueo?", new_unlock_path(resource_name), class: link_class %></p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <p><%= button_to "Entrar con #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "text-sm" %></p>
  <% end %>
<% end %>
