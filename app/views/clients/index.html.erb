<% content_for :title, "Clientes — SoloIVA" %>

<div class="mb-6 flex items-center justify-between">
  <h1 class="text-2xl font-bold text-brand-navy">Clientes</h1>
  <%= link_to "+ Nuevo cliente", new_client_path, class: "text-sm px-4 py-2 rounded bg-brand-teal text-white hover:bg-brand-teal-dark" %>
</div>

<% if @clients.any? %>
  <div class="bg-white rounded-lg border overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
        <tr>
          <th class="px-4 py-3 text-left">Nombre</th>
          <th class="px-4 py-3 text-left">NIF</th>
          <th class="px-4 py-3 text-left">Ciudad</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @clients.each do |c| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium"><%= c.name %></td>
            <td class="px-4 py-3 text-gray-600"><%= c.nif.presence || "—" %></td>
            <td class="px-4 py-3 text-gray-600"><%= c.city.presence || "—" %></td>
            <td class="px-4 py-3 text-right space-x-2">
              <%= link_to "Editar", edit_client_path(c), class: "text-brand-navy hover:text-brand-teal hover:underline text-xs" %>
              <%= button_to "Eliminar", client_path(c), method: :delete, data: { turbo_confirm: "¿Eliminar este cliente? Las facturas ya creadas conservan los datos." }, class: "text-red-500 hover:underline text-xs bg-transparent border-0 cursor-pointer inline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-gray-500">Aún no hay clientes. <%= link_to "Crea el primero", new_client_path, class: "text-brand-navy hover:text-brand-teal hover:underline" %> para facturas emitidas.</p>
<% end %>
