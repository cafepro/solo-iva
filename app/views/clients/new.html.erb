<% content_for :title, "Nuevo cliente — SoloIVA" %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Nuevo cliente</h1>
</div>

<div class="bg-white rounded-lg border p-6">
  <%= form_with model: @client, class: "space-y-6" do |f| %>
    <%= render "form", f: f, client: @client %>
    <div class="flex gap-3">
      <%= f.submit "Guardar", class: "bg-blue-600 text-white px-5 py-2 rounded text-sm font-medium cursor-pointer" %>
      <%= link_to "Cancelar", clients_path, class: "text-sm text-gray-500 hover:underline self-center" %>
    </div>
  <% end %>
</div>
