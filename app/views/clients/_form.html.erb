<%= render "shared/errors", object: client %>

<div class="space-y-4 max-w-lg">
  <div>
    <%= f.label :name, "Nombre o razón social", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
  </div>
  <div>
    <%= f.label :nif, "NIF / CIF / VAT", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :nif, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
  </div>
  <div>
    <%= f.label :address_line, "Dirección", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :address_line, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :postal_code, "Código postal", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :postal_code, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :city, "Ciudad", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :city, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :province, "Provincia", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :province, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :country, "País", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :country, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
  </div>
</div>
