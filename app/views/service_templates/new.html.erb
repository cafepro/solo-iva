<% content_for :title, "Nueva plantilla de tarifa — SoloIVA" %>

<div class="bg-white rounded-lg border p-6">
  <%= form_with model: @service_template, class: "space-y-6" do |f| %>
    <%= render "form", f: f, service_template: @service_template %>
    <div class="flex gap-3">
      <%= f.submit "Guardar", class: "bg-brand-teal text-white px-5 py-2 rounded text-sm font-medium cursor-pointer hover:bg-brand-teal-dark" %>
      <%= link_to "Cancelar", service_templates_path, class: "text-sm text-brand-navy/60 hover:text-brand-teal hover:underline self-center" %>
    </div>
  <% end %>
</div>
