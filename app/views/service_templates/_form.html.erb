<%= render "shared/errors", object: service_template %>

<div class="space-y-4 max-w-lg">
  <div>
    <%= f.label :name, "Nombre (ej. Coworking mensual)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
  </div>
  <div>
    <%= f.label :billing_period, "Periodo de servicio al aplicar", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :billing_period,
          ServiceTemplate.billing_period_select_options,
          {},
          class: "w-full border border-gray-300 rounded px-3 py-2 text-sm bg-white" %>
    <p class="text-xs text-gray-500 mt-1">Se calcula a partir de la <strong>fecha de factura</strong> al elegir la plantilla en el formulario.</p>
  </div>
  <div>
    <%= f.label :default_description, "Concepto por defecto (primera línea)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :default_description, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm", placeholder: "ej. Cuota espacio coworking — abril 2026" %>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :default_base_imponible, "Base imponible (€)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :default_base_imponible, step: "0.01", class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :default_iva_rate, "Tipo IVA", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :default_iva_rate,
            [ [ "21%", 21 ], [ "10%", 10 ], [ "4%", 4 ], [ "0%", 0 ] ],
            {},
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm bg-white" %>
    </div>
  </div>
</div>
