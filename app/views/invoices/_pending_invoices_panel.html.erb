<div id="pending_invoices_<%= invoice_type %>" class="space-y-4">
  <% if invoices.any? %>
    <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">
      Facturas pendientes de confirmar (<%= invoices.count %>)
    </h2>
    <%= render partial: "invoices/pending_invoice_card", collection: invoices, as: :invoice %>
  <% else %>
    <div class="py-16 text-center text-gray-400">
      <p class="mb-1 text-lg">No hay facturas pendientes</p>
      <p class="text-sm">Sube un PDF o una foto para empezar.</p>
    </div>
  <% end %>
</div>
