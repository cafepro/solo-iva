<div class="bg-white rounded-lg border p-6"
     data-controller="invoice-form invoice-emitida"
     data-invoice-form-upload-url-value="<%= upload_pdf_invoices_path %>"
     data-invoice-form-bulk-create-url-value="<%= bulk_create_invoices_path %>"
     data-invoice-form-line-index-value="<%= invoice.invoice_lines.size %>"
     data-invoice-emitida-service-templates-base-value="<%= service_templates_path %>"
     data-invoice-emitida-clients-snapshot-value="<%= ERB::Util.html_escape(@clients_snapshot_json.presence || "{}") %>">

  <%# PDF UPLOAD (oculto en emitidas: se genera la factura en la app) %>
  <div class="mb-6" data-invoice-emitida-target="emitidaUpload">
    <div data-invoice-form-target="dropzone"
         data-action="dragover->invoice-form#onDragOver dragleave->invoice-form#onDragLeave drop->invoice-form#onDrop click->invoice-form#openFilePicker"
         class="relative flex flex-col items-center justify-center gap-2 p-6 rounded-lg border-2 border-dashed border-blue-300 bg-blue-50 cursor-pointer transition-colors hover:bg-blue-100 hover:border-blue-400">
      <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <p class="text-sm font-medium text-blue-700">Arrastra un PDF o una foto de la factura o <span class="underline">selecciona un archivo</span></p>
      <p class="text-xs text-blue-500">Rellenaremos los campos automáticamente (JPG, PNG o WebP). Podrás revisar antes de guardar.</p>
      <span data-invoice-form-target="status" class="text-xs font-medium text-blue-700 hidden"></span>
      <input type="file" accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/jpeg,image/png,image/webp"
             data-invoice-form-target="fileInput"
             data-action="change->invoice-form#onFileChange"
             class="sr-only">
    </div>
  </div>

  <%= form_with model: invoice, class: "space-y-5" do |f| %>
    <input type="hidden" name="invoice[source_stash_token]" id="invoice_source_stash_token" value="" autocomplete="off">
    <%= render "shared/errors", object: invoice %>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :invoice_type, "Tipo de factura", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :invoice_type,
            [["Emitida (venta)", "emitida"], ["Recibida (gasto)", "recibida"]],
            {},
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
            id: "invoice_invoice_type" %>
      </div>
      <div>
        <%= f.label :invoice_number, "Número de factura", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :invoice_number, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", id: "invoice_invoice_number" %>
        <% if invoice.persisted? && invoice.emitida? && @suggested_invoice_number.present? %>
          <p class="text-xs text-gray-500 mt-1">Siguiente en serie al crear una nueva: <span class="font-mono"><%= @suggested_invoice_number %></span></p>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= render "shared/date_field_with_picker",
              f: f,
              method: :invoice_date,
              label_text: "Fecha",
              id: "invoice_invoice_date" %>
      </div>
    </div>

    <div class="hidden space-y-4 border border-blue-100 bg-blue-50/40 rounded-lg p-4" data-invoice-emitida-target="emitidaSection">
      <p class="text-xs font-semibold text-blue-800 uppercase tracking-wide">Factura emitida</p>
      <% if invoice.new_record? %>
        <div class="flex items-start gap-2">
          <%= hidden_field_tag "use_auto_invoice_number", "0" %>
          <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
            <%= check_box_tag "use_auto_invoice_number", "1", true, class: "rounded border-gray-300 mt-0.5" %>
            <span><strong>Numeración automática</strong> (<%= link_to "prefijo y dígitos", billing_profile_path, class: "text-blue-600 hover:underline" %>). Se usará el siguiente: <span class="font-mono font-medium"><%= @suggested_invoice_number || "—" %></span>. Desmárcalo para escribir el número a mano.</span>
          </label>
        </div>
      <% end %>
      <div class="flex flex-wrap items-end gap-3">
        <div class="flex-1 min-w-[12rem]">
          <%= f.label :client_id, "Cliente", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.collection_select :client_id,
                @clients || [],
                :id,
                :name,
                { include_blank: "Sin cliente (rellenar receptor a mano)" },
                class: "w-full border border-gray-300 rounded px-3 py-2 text-sm bg-white",
                id: "invoice_client_id",
                data: { action: "change->invoice-emitida#clientChanged" } %>
        </div>
        <%= link_to "Nuevo cliente", new_client_path, class: "text-sm text-blue-600 hover:underline pb-2" %>
        <%= link_to "Datos de facturación (emisor, IBAN…)", billing_profile_path, class: "text-sm text-gray-600 hover:underline pb-2" %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <%= render "shared/date_field_with_picker",
                f: f,
                method: :service_period_start,
                label_text: "Periodo servicio — inicio",
                id: "invoice_service_period_start",
                label_class: "block text-xs font-medium text-gray-600 mb-1" %>
        </div>
        <div>
          <%= render "shared/date_field_with_picker",
                f: f,
                method: :service_period_end,
                label_text: "Periodo servicio — fin",
                id: "invoice_service_period_end",
                label_class: "block text-xs font-medium text-gray-600 mb-1" %>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row sm:flex-wrap gap-3 sm:items-end">
        <div class="flex-1 min-w-[12rem]">
          <label class="block text-xs font-medium text-gray-600 mb-1">Plantilla de tarifa</label>
          <% if (@service_templates || []).any? %>
            <select id="invoice_service_template_picker"
                    class="w-full border border-gray-300 rounded px-3 py-2 text-sm bg-white"
                    data-action="change->invoice-emitida#applyServiceTemplate">
              <option value="">Elegir plantilla…</option>
              <% @service_templates.each do |tpl| %>
                <option value="<%= tpl.id %>"><%= tpl.name %></option>
              <% end %>
            </select>
          <% else %>
            <p class="text-xs text-gray-500 py-2">
              <%= link_to "Crea plantillas", service_templates_path, class: "text-blue-600 hover:underline" %> para rellenar periodo, concepto e importes de un clic.
            </p>
          <% end %>
        </div>
        <div class="flex-1 min-w-[12rem]">
          <label class="block text-xs font-medium text-gray-600 mb-1">Rellenar solo periodo (fecha de factura)</label>
          <select class="w-full border border-gray-300 rounded px-3 py-2 text-sm bg-white"
                  data-action="change->invoice-emitida#setPeriodPreset">
            <option value="">Elegir…</option>
            <option value="day">Un día (solo la fecha de factura)</option>
            <option value="week">Semana natural (lun–dom)</option>
            <option value="month">Mes natural de la fecha</option>
          </select>
        </div>
      </div>

      <div>
        <%= f.label :payment_signed_note, "Formas de pago en PDF (opcional, sustituye al texto guardado en perfil)", class: "block text-xs font-medium text-gray-600 mb-1" %>
        <%= f.text_field :payment_signed_note,
            placeholder: "ej. Cash / Bizum / Paypal / Bank Transfer",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm bg-white" %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :issuer_name, "Emisor (nombre / empresa)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :issuer_name, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", id: "invoice_issuer_name" %>
      </div>
      <div>
        <%= f.label :issuer_nif, "NIF / CIF del emisor", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :issuer_nif, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", id: "invoice_issuer_nif" %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :recipient_name, "Receptor (nombre / empresa)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :recipient_name, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", id: "invoice_recipient_name" %>
      </div>
      <div>
        <%= f.label :recipient_nif, "NIF / CIF del receptor", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :recipient_nif, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", id: "invoice_recipient_nif" %>
      </div>
    </div>

    <div class="hidden space-y-3 border border-gray-100 rounded-lg p-4 bg-gray-50/50" data-invoice-emitida-target="emitidaSection">
      <p class="text-xs font-medium text-gray-600">Dirección del cliente (en factura y PDF)</p>
      <div class="grid grid-cols-1 gap-3">
        <%= f.text_field :recipient_address_line, placeholder: "Calle y número", class: "w-full border border-gray-300 rounded px-3 py-2 text-sm", id: "invoice_recipient_address_line" %>
        <div class="grid grid-cols-2 gap-3">
          <%= f.text_field :recipient_postal_code, placeholder: "C.P.", class: "w-full border border-gray-300 rounded px-3 py-2 text-sm", id: "invoice_recipient_postal_code" %>
          <%= f.text_field :recipient_city, placeholder: "Ciudad", class: "w-full border border-gray-300 rounded px-3 py-2 text-sm", id: "invoice_recipient_city" %>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <%= f.text_field :recipient_province, placeholder: "Provincia", class: "w-full border border-gray-300 rounded px-3 py-2 text-sm", id: "invoice_recipient_province" %>
          <%= f.text_field :recipient_country, placeholder: "País", class: "w-full border border-gray-300 rounded px-3 py-2 text-sm", id: "invoice_recipient_country" %>
        </div>
      </div>
    </div>

    <%# LÍNEAS DE IVA %>
    <div>
      <div class="flex items-center justify-between mb-2">
        <label class="text-sm font-medium text-gray-700">Líneas de IVA</label>
        <button type="button"
                data-action="click->invoice-form#addLine"
                class="text-xs text-blue-600 hover:underline">+ Añadir línea</button>
      </div>
      <div data-invoice-form-target="linesContainer" class="space-y-2">
        <%= f.fields_for :invoice_lines do |lf| %>
          <%= render "invoice_line_fields", f: lf %>
        <% end %>
      </div>
    </div>

    <%= f.label :notes, "Notas internas (opcional, no salen en el PDF)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :notes, rows: 2, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>

    <div class="flex gap-3 pt-2">
      <%= f.submit "Guardar factura", class: "bg-blue-600 text-white px-5 py-2 rounded hover:bg-blue-700 text-sm font-medium cursor-pointer" %>
      <%= link_to "Cancelar", invoices_path, class: "text-sm text-gray-500 hover:underline self-center" %>
    </div>
  <% end %>

  <%# Template for new IVA line rows %>
  <template data-invoice-form-target="lineTemplate">
  <div class="line-row flex flex-col gap-2 p-3 bg-gray-50 rounded border">
    <div class="flex gap-3 items-start">
      <div class="flex-1 min-w-0">
        <label class="text-xs text-gray-500">Concepto (PDF)</label>
        <input type="text" name="invoice[invoice_lines_attributes][NEW_RECORD][description]"
               class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm" placeholder="ej. 1 month space rent">
      </div>
    </div>
    <div class="flex gap-3 items-center flex-wrap">
      <div class="flex-1 min-w-[6rem]">
        <label class="text-xs text-gray-500">Tipo IVA</label>
        <select name="invoice[invoice_lines_attributes][NEW_RECORD][iva_rate]" class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm">
          <option value="21">21%</option>
          <option value="10">10%</option>
          <option value="4">4%</option>
          <option value="0">0%</option>
        </select>
      </div>
      <div class="flex-1 min-w-[6rem]">
        <label class="text-xs text-gray-500">Base imponible (€)</label>
        <input type="number" step="0.01" name="invoice[invoice_lines_attributes][NEW_RECORD][base_imponible]"
               class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm">
      </div>
      <div class="flex-1 min-w-[6rem]">
        <label class="text-xs text-gray-500">Cuota IVA (€) — calculada</label>
        <input type="number" step="0.01" class="w-full border border-gray-200 bg-gray-100 rounded px-2 py-1.5 text-sm" readonly placeholder="auto">
      </div>
      <button type="button" class="remove-line text-red-400 hover:text-red-600 text-lg self-end">&times;</button>
    </div>
  </div>
  </template>
</div>
