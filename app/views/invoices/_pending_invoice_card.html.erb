<div id="pending_invoice_<%= invoice.id %>" class="bg-white rounded-lg border p-5 space-y-4">
  <% if local_assigns[:confirm_error].present? %>
    <div class="rounded border border-red-200 bg-red-50 text-red-800 text-sm px-3 py-2" role="alert">
      <%= confirm_error %>
    </div>
  <% end %>
  <% if invoice.duplicate_with_confirmed_invoice? %>
    <div class="rounded border border-amber-200 bg-amber-50 text-amber-900 text-sm px-3 py-2">
      Ya tienes una factura <strong>confirmada</strong> con este número (mismo tipo). Debes cambiar el número o descartar esta copia antes de confirmar.
    </div>
  <% end %>
  <% if invoice.duplicate_with_other_pending_invoice? %>
    <div class="rounded border border-amber-200 bg-amber-50 text-amber-900 text-sm px-3 py-2">
      Hay otra factura <strong>pendiente</strong> con el mismo número. Revisa duplicados en «Revisión» o edita el número.
    </div>
  <% end %>
  <div class="flex items-start justify-between gap-4">
    <div class="space-y-1">
      <div class="flex items-center gap-2">
        <span class="text-xs px-2 py-0.5 rounded-full <%= invoice.emitida? ? 'bg-brand-muted text-brand-navy' : 'bg-brand-teal-muted text-brand-teal-dark' %>">
          <%= invoice.emitida? ? "Emitida" : "Recibida" %>
        </span>
        <span class="font-semibold text-gray-800"><%= invoice.invoice_number %></span>
        <% if invoice.invoice_date %>
          <span class="text-sm text-gray-400"><%= invoice.invoice_date.strftime("%d/%m/%Y") %></span>
        <% end %>
      </div>
      <p class="text-sm text-gray-600">
        <%= invoice.issuer_name.presence || "Emisor desconocido" %>
        <% if invoice.issuer_nif.present? %>
          <span class="text-gray-400">· <%= invoice.issuer_nif %></span>
        <% end %>
      </p>
    </div>
    <div class="text-right shrink-0">
      <p class="text-xs text-gray-400 uppercase tracking-wide">Total</p>
      <p class="font-bold text-gray-800"><%= number_to_currency(invoice.total, unit: "€", separator: ",", delimiter: ".") %></p>
    </div>
  </div>

  <% if invoice.invoice_lines.any? %>
    <div class="text-xs text-gray-500 border-t pt-3 space-y-1">
      <% invoice.invoice_lines.each do |line| %>
        <div class="flex justify-between">
          <span>Base <%= line.iva_rate.to_i %>% IVA</span>
          <span><%= number_to_currency(line.base_imponible, unit: "€", separator: ",", delimiter: ".") %> + <%= number_to_currency(line.iva_amount, unit: "€", separator: ",", delimiter: ".") %></span>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="flex gap-2 pt-1">
    <%= button_to confirm_invoice_path(invoice), method: :patch,
        class: "bg-brand-teal text-white px-4 py-1.5 rounded text-sm font-medium hover:bg-brand-teal-dark transition-colors cursor-pointer" do %>
      Confirmar
    <% end %>
    <%= link_to "Editar", edit_invoice_path(invoice),
        class: "px-4 py-1.5 rounded text-sm text-brand-navy border border-brand-navy/25 hover:bg-brand-muted transition-colors" %>
    <%= button_to invoice_path(invoice, return_to: "review"), method: :delete,
        data: { turbo_confirm: "¿Descartar esta factura pendiente?" },
        class: "px-3 py-1.5 rounded text-sm text-red-400 hover:text-red-600 hover:bg-red-50 border-0 bg-transparent cursor-pointer" do %>
      Descartar
    <% end %>
  </div>
</div>
