<div class="line-row flex flex-col gap-2 p-3 bg-gray-50 rounded border">
  <%= f.hidden_field :_destroy, class: "destroy-flag" %>
  <div class="flex gap-3 items-start">
    <div class="flex-1 min-w-0">
      <label class="text-xs text-gray-500">Concepto (PDF)</label>
      <%= f.text_field :description, class: "w-full border border-gray-300 rounded px-2 py-1.5 text-sm", placeholder: "ej. 1 month space rent" %>
    </div>
  </div>
  <div class="flex gap-3 items-center flex-wrap">
    <div class="flex-1 min-w-[6rem]">
      <label class="text-xs text-gray-500">Tipo IVA</label>
      <%= f.select :iva_rate,
          [[" 21%", 21], ["10%", 10], [" 4%", 4], [" 0%", 0]],
          {},
          class: "w-full border border-gray-300 rounded px-2 py-1.5 text-sm" %>
    </div>
    <div class="flex-1 min-w-[6rem]">
      <label class="text-xs text-gray-500">Base imponible (€)</label>
      <%= f.number_field :base_imponible, step: "0.01", class: "w-full border border-gray-300 rounded px-2 py-1.5 text-sm" %>
    </div>
    <div class="flex-1 min-w-[6rem]">
      <label class="text-xs text-gray-500">Cuota IVA (€) — calculada</label>
      <input type="number" step="0.01" value="<%= f.object.iva_amount %>" class="w-full border border-gray-200 bg-gray-100 rounded px-2 py-1.5 text-sm" readonly>
    </div>
    <button type="button" class="remove-line text-red-400 hover:text-red-600 text-lg self-end">&times;</button>
  </div>
</div>
