<% content_for :title, "Subir facturas — SoloIVA" %>
<% content_for :section_title do %>
  Subir facturas — <%= @invoice_type == "emitida" ? "Emitidas" : "Recibidas" %>
<% end %>

<%= turbo_stream_from "pdf_uploads_#{current_user.id}_#{@invoice_type}" %>
<%= turbo_stream_from "pending_invoices_#{current_user.id}_#{@invoice_type}" %>

<%# PDF UPLOAD ZONE %>
<div class="mb-8 rounded-lg border bg-white p-6"
     data-controller="pdf-upload"
     data-pdf-upload-url-value="<%= upload_pdfs_invoices_path %>"
     data-pdf-upload-invoice-type-value="<%= @invoice_type %>">

  <h2 class="mb-3 text-sm font-semibold text-gray-700">Subir PDF o fotos</h2>
  <p class="mb-3 text-xs text-gray-500">
    Las facturas creadas serán <strong><%= @invoice_type == "emitida" ? "emitidas (ventas)" : "recibidas (gastos)" %></strong>; no hace falta que la IA indique el tipo.
  </p>

  <div data-pdf-upload-target="dropzone"
       data-action="dragover->pdf-upload#onDragOver dragleave->pdf-upload#onDragLeave drop->pdf-upload#onDrop click->pdf-upload#openFilePicker"
       class="flex cursor-pointer flex-col items-center justify-center gap-2 rounded-lg border-2 border-dashed border-brand-teal/35 bg-brand-teal-muted p-6 transition-colors hover:border-brand-teal/55 hover:bg-brand-teal-soft">
    <svg class="h-8 w-8 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>
    <p class="text-sm font-medium text-brand-navy">Arrastra PDFs o fotos (JPG, PNG, WebP) o <span class="underline">selecciona archivos</span></p>
    <p class="text-xs text-brand-teal-dark/90">Cada archivo se procesa en segundo plano. Abajo podrás revisarlas y confirmarlas.</p>
    <input type="file" accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/jpeg,image/png,image/webp" multiple
           data-pdf-upload-target="fileInput"
           data-action="change->pdf-upload#onFileChange"
           class="sr-only">
  </div>

  <% if @uploads.any? %>
    <div id="upload_queue" class="mt-4 space-y-2">
      <p class="mb-1 text-xs font-medium uppercase tracking-wide text-gray-500">En proceso</p>
      <% @uploads.each do |upload| %>
        <%= render "invoices/pdf_upload_row", upload: upload %>
      <% end %>
    </div>
  <% else %>
    <div id="upload_queue" class="mt-4 space-y-2"></div>
  <% end %>
</div>

<%# PENDING INVOICES %>
<%= render "invoices/pending_invoices_panel", invoices: @pending, invoice_type: @invoice_type %>
