<% content_for :title, "Revisión de facturas — SoloIVA" %>

<%= turbo_stream_from "pdf_uploads_#{current_user.id}" %>
<%= turbo_stream_from "pending_invoices_#{current_user.id}" %>
<%= turbo_stream_from "pending_badge_#{current_user.id}" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Revisión de facturas</h1>
</div>

<%# PDF UPLOAD ZONE %>
<div class="mb-8 bg-white rounded-lg border p-6"
     data-controller="pdf-upload"
     data-pdf-upload-url-value="<%= upload_pdfs_invoices_path %>">

  <h2 class="text-sm font-semibold text-gray-700 mb-3">Subir PDFs</h2>

  <div data-pdf-upload-target="dropzone"
       data-action="dragover->pdf-upload#onDragOver dragleave->pdf-upload#onDragLeave drop->pdf-upload#onDrop click->pdf-upload#openFilePicker"
       class="flex flex-col items-center justify-center gap-2 p-6 rounded-lg border-2 border-dashed border-blue-300 bg-blue-50 cursor-pointer transition-colors hover:bg-blue-100 hover:border-blue-400">
    <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>
    <p class="text-sm font-medium text-blue-700">Arrastra uno o varios PDFs aquí o <span class="underline">selecciona archivos</span></p>
    <p class="text-xs text-blue-500">Cada PDF se procesará en segundo plano. Las facturas aparecerán abajo para revisión.</p>
    <input type="file" accept=".pdf" multiple
           data-pdf-upload-target="fileInput"
           data-action="change->pdf-upload#onFileChange"
           class="sr-only">
  </div>

  <% if @uploads.any? %>
    <div id="upload_queue" class="mt-4 space-y-2">
      <p class="text-xs text-gray-500 uppercase tracking-wide font-medium mb-1">En proceso</p>
      <% @uploads.each do |upload| %>
        <%= render "invoices/pdf_upload_row", upload: upload %>
      <% end %>
    </div>
  <% else %>
    <div id="upload_queue" class="mt-4 space-y-2"></div>
  <% end %>
</div>

<%# PENDING INVOICES %>
<div id="pending_invoices" class="space-y-4">
  <% if @pending.any? %>
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">
      Facturas pendientes de revisión (<%= @pending.count %>)
    </h2>
    <%= render partial: "pending_invoice_card", collection: @pending, as: :invoice %>
  <% else %>
    <div class="text-center py-16 text-gray-400">
      <p class="text-lg mb-1">No hay facturas pendientes</p>
      <p class="text-sm">Sube un PDF para empezar.</p>
    </div>
  <% end %>
</div>
