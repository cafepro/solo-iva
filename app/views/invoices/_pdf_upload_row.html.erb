<div id="pdf_upload_<%= upload.id %>" class="flex items-center gap-3 px-4 py-2 text-sm bg-white rounded-lg border">
  <% if upload.pending? || upload.processing? %>
    <svg class="w-4 h-4 text-brand-teal animate-spin" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
    </svg>
  <% elsif upload.done? %>
    <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
    </svg>
  <% else %>
    <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  <% end %>
  <span class="flex-1 text-gray-700 truncate"><%= upload.filename %></span>
  <span class="text-xs text-gray-400"><%= upload.failed? ? "Error" : upload.status.capitalize %></span>
  <% if upload.pending? || upload.processing? %>
    <%= button_to pdf_upload_path(upload), method: :delete,
        form: { data: { turbo_confirm: "¿Descartar esta subida?" } },
        class: "shrink-0 text-xs text-gray-500 hover:text-red-600 px-2 py-1 rounded hover:bg-red-50 cursor-pointer border-0 bg-transparent" do %>
      Cancelar
    <% end %>
  <% elsif upload.done? || upload.failed? %>
    <%= button_to pdf_upload_path(upload), method: :delete,
        form: { data: { turbo_confirm: "¿Quitar esta fila de la lista?" } },
        class: "shrink-0 text-xs text-gray-500 hover:text-red-600 px-2 py-1 rounded hover:bg-red-50 cursor-pointer border-0 bg-transparent" do %>
      Quitar
    <% end %>
  <% end %>
  <% if upload.failed? && upload.error_message.present? %>
    <%= tag.span truncate(upload.error_message, length: 90),
          class: "text-xs text-red-600 truncate max-w-[min(28rem,55vw)]",
          title: upload.error_message %>
  <% end %>
</div>
