<%# rate: numeric IVA type (0, 4, 10, 21) — no importe en euros %>
<% texto = number_with_precision(rate, precision: 2, separator: ",", delimiter: ".") %>
<div class="flex items-center justify-end gap-1.5">
  <span class="tabular-nums text-brand-navy/90"><%= texto %> %</span>
  <%= render "shared/clipboard_copy_icon_button",
        copy_value: texto,
        title: "Copiar el tipo impositivo (formato español)" %>
</div>
