<% content_for :title, "Modelo 303 — SoloIVA" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Modelo 303</h1>
    <p class="text-sm text-gray-500"><%= @year %> — Trimestre <%= @quarter %></p>
  </div>
  <div class="flex gap-2 flex-wrap">
    <% [Date.today.year, Date.today.year - 1].each do |y| %>
      <% [1, 2, 3, 4].each do |q| %>
        <%= link_to "#{y} T#{q}", modelo303_reports_path(year: y, quarter: q),
            class: "text-xs px-2 py-1 rounded #{@year == y && @quarter == q ? 'bg-blue-600 text-white' : 'bg-white border text-gray-600 hover:bg-gray-100'}" %>
      <% end %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

  <%# IVA DEVENGADO %>
  <div class="bg-white rounded-lg border overflow-hidden">
    <div class="bg-blue-600 text-white px-4 py-3">
      <h2 class="font-semibold text-sm uppercase tracking-wide">IVA Devengado — Facturas Emitidas</h2>
    </div>
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-xs">
        <tr>
          <th class="px-4 py-2 text-left">Casilla</th>
          <th class="px-4 py-2 text-left">Descripción</th>
          <th class="px-4 py-2 text-right font-bold">Importe</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-mono text-blue-700 font-bold">01</td>
          <td class="px-4 py-3 text-gray-600">Base imponible al 21%</td>
          <td class="px-4 py-3 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_01] %></td>
        </tr>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-mono text-blue-700 font-bold">02</td>
          <td class="px-4 py-3 text-gray-600">Cuota al 21%</td>
          <td class="px-4 py-3 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_02] %></td>
        </tr>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-mono text-blue-700 font-bold">03</td>
          <td class="px-4 py-3 text-gray-600">Base imponible al 10%</td>
          <td class="px-4 py-3 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_03] %></td>
        </tr>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-mono text-blue-700 font-bold">04</td>
          <td class="px-4 py-3 text-gray-600">Cuota al 10%</td>
          <td class="px-4 py-3 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_04] %></td>
        </tr>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-mono text-blue-700 font-bold">05</td>
          <td class="px-4 py-3 text-gray-600">Base imponible al 4%</td>
          <td class="px-4 py-3 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_05] %></td>
        </tr>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-mono text-blue-700 font-bold">06</td>
          <td class="px-4 py-3 text-gray-600">Cuota al 4%</td>
          <td class="px-4 py-3 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_06] %></td>
        </tr>
        <tr class="bg-blue-50 font-bold">
          <td class="px-4 py-3 font-mono text-blue-800">46</td>
          <td class="px-4 py-3 text-blue-800">TOTAL IVA devengado</td>
          <td class="px-4 py-3 text-right text-blue-800"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_46] %></td>
        </tr>
      </tbody>
    </table>
  </div>

  <%# IVA DEDUCIBLE %>
  <div class="bg-white rounded-lg border overflow-hidden">
    <div class="bg-orange-500 text-white px-4 py-3">
      <h2 class="font-semibold text-sm uppercase tracking-wide">IVA Deducible — Facturas Recibidas</h2>
    </div>
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-xs">
        <tr>
          <th class="px-4 py-2 text-left">Casilla</th>
          <th class="px-4 py-2 text-left">Descripción</th>
          <th class="px-4 py-2 text-right font-bold">Importe</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-mono text-orange-600 font-bold">28</td>
          <td class="px-4 py-3 text-gray-600">Base imponible deducible</td>
          <td class="px-4 py-3 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_28] %></td>
        </tr>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-mono text-orange-600 font-bold">29</td>
          <td class="px-4 py-3 text-gray-600">Cuota deducible</td>
          <td class="px-4 py-3 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_29] %></td>
        </tr>
        <tr class="bg-orange-50 font-bold">
          <td class="px-4 py-3 font-mono text-orange-800">47</td>
          <td class="px-4 py-3 text-orange-800">TOTAL IVA deducible</td>
          <td class="px-4 py-3 text-right text-orange-800"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_47] %></td>
        </tr>
      </tbody>
    </table>

    <%# RESULTADO %>
    <div class="border-t-2 border-gray-200 mt-2">
      <div class="px-4 py-4 <%= @report[:casilla_64] >= 0 ? 'bg-red-50' : 'bg-green-50' %>">
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3">
          <div>
            <span class="font-mono font-bold text-lg <%= @report[:casilla_64] >= 0 ? 'text-red-700' : 'text-green-700' %>">64</span>
            <span class="ml-2 font-semibold text-gray-700">Resultado</span>
          </div>
          <div class="text-right">
            <div class="flex flex-wrap items-center justify-end gap-2">
              <p class="text-2xl font-bold tabular-nums <%= @report[:casilla_64] >= 0 ? 'text-red-600' : 'text-green-600' %>">
                <%= number_to_currency(@report[:casilla_64], unit: "€", separator: ",", delimiter: ".") %>
              </p>
              <button type="button"
                      class="shrink-0 rounded border border-gray-200 bg-white px-2 py-1 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:border-gray-300 transition-colors"
                      data-controller="clipboard-copy"
                      data-clipboard-copy-text-value="<%= modelo303_copy_value(@report[:casilla_64]) %>"
                      data-action="clipboard-copy#copy"
                      title="Copiar importe con formato español (miles con punto, decimales con coma)">
                Copiar
              </button>
            </div>
            <p class="text-xs text-gray-500 mt-1"><%= @report[:casilla_64] >= 0 ? "A ingresar en Hacienda" : "A devolver / compensar" %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="mt-6 text-center">
  <%= link_to invoices_path(invoice_type: "emitida", year: @year, quarter: @quarter), class: "text-sm text-blue-600 hover:underline mr-4" do %>
    Ver facturas emitidas de este trimestre
  <% end %>
  <%= link_to invoices_path(invoice_type: "recibida", year: @year, quarter: @quarter), class: "text-sm text-orange-600 hover:underline" do %>
    Ver facturas recibidas de este trimestre
  <% end %>
</div>
