<% content_for :title, "Modelo 303 — SoloIVA" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-brand-navy">Modelo 303</h1>
    <p class="text-sm text-gray-500"><%= @year %> — Trimestre <%= @quarter %> · Casillas según instrucciones AEAT 2026 (régimen general)</p>
  </div>
  <div class="flex gap-2 flex-wrap">
    <% [Date.today.year, Date.today.year - 1].each do |y| %>
      <% [1, 2, 3, 4].each do |q| %>
        <%= link_to "#{y} T#{q}", modelo303_reports_path(year: y, quarter: q),
            class: "text-xs px-2 py-1 rounded #{@year == y && @quarter == q ? 'bg-brand-teal text-white shadow-sm' : 'bg-white border border-gray-200 text-brand-navy/80 hover:bg-brand-muted hover:border-brand-navy/25'}" %>
      <% end %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

  <%# IVA DEVENGADO — orden y numeración como modelo en línea 2026 %>
  <div class="bg-white rounded-lg border overflow-hidden">
    <div class="bg-brand-navy text-white px-4 py-3">
      <h2 class="font-semibold text-sm uppercase tracking-wide">IVA devengado — Régimen general</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[32rem]">
        <thead class="bg-brand-muted text-brand-navy/75 text-xs">
          <tr>
            <th class="px-3 py-2 text-left">Casilla</th>
            <th class="px-3 py-2 text-left">Concepto</th>
            <th class="px-3 py-2 text-right font-bold">Importe</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <tr class="bg-gray-50/80">
            <td colspan="3" class="px-3 py-2 text-xs font-semibold text-gray-600 uppercase tracking-wide">Tipo 4 %</td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">01</td>
            <td class="px-3 py-2 text-gray-600">Base imponible</td>
            <td class="px-3 py-2 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_01] %></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">02</td>
            <td class="px-3 py-2 text-gray-600">Tipo %</td>
            <td class="px-3 py-2 text-right"><%= render "reports/modelo303_tipo_cell", rate: 4 %></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">03</td>
            <td class="px-3 py-2 text-gray-600">Cuota</td>
            <td class="px-3 py-2 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_03] %></td>
          </tr>

          <tr class="bg-gray-50/80">
            <td colspan="3" class="px-3 py-2 text-xs font-semibold text-gray-600 uppercase tracking-wide">Tipo 10 %</td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">04</td>
            <td class="px-3 py-2 text-gray-600">Base imponible</td>
            <td class="px-3 py-2 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_04] %></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">05</td>
            <td class="px-3 py-2 text-gray-600">Tipo %</td>
            <td class="px-3 py-2 text-right"><%= render "reports/modelo303_tipo_cell", rate: 10 %></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">06</td>
            <td class="px-3 py-2 text-gray-600">Cuota</td>
            <td class="px-3 py-2 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_06] %></td>
          </tr>

          <tr class="bg-gray-50/80">
            <td colspan="3" class="px-3 py-2 text-xs font-semibold text-gray-600 uppercase tracking-wide">Tipo 21 %</td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">07</td>
            <td class="px-3 py-2 text-gray-600">Base imponible</td>
            <td class="px-3 py-2 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_07] %></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">08</td>
            <td class="px-3 py-2 text-gray-600">Tipo %</td>
            <td class="px-3 py-2 text-right"><%= render "reports/modelo303_tipo_cell", rate: 21 %></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">09</td>
            <td class="px-3 py-2 text-gray-600">Cuota</td>
            <td class="px-3 py-2 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_09] %></td>
          </tr>

          <tr class="bg-gray-50/80">
            <td colspan="3" class="px-3 py-2 text-xs font-semibold text-gray-600 uppercase tracking-wide">Tipo 0 %</td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">150</td>
            <td class="px-3 py-2 text-gray-600">Base imponible</td>
            <td class="px-3 py-2 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_150] %></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">151</td>
            <td class="px-3 py-2 text-gray-600">Tipo %</td>
            <td class="px-3 py-2 text-right"><%= render "reports/modelo303_tipo_cell", rate: 0 %></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-brand-navy font-bold">152</td>
            <td class="px-3 py-2 text-gray-600">Cuota</td>
            <td class="px-3 py-2 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_152] %></td>
          </tr>

          <tr class="bg-brand-muted/80 font-bold">
            <td class="px-3 py-3 font-mono text-brand-navy">27</td>
            <td class="px-3 py-3 text-brand-navy">Total cuota devengada (aplicación: suma de cuotas del apartado que correspondan)</td>
            <td class="px-3 py-3 text-right text-brand-navy"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_27] %></td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="px-4 py-2 text-xs text-gray-500 border-t border-gray-100">
      La 27 en el modelo oficial incluye más conceptos (intragrupo, recargo equivalencia, etc.). Aquí solo sumamos las cuotas 03, 06, 09 y 152 según tus facturas emitidas en la app.
    </p>
  </div>

  <%# IVA DEDUCIBLE — cabecera en teal (devengado va en navy) %>
  <div class="bg-white rounded-lg border overflow-hidden">
    <div class="bg-brand-teal text-white px-4 py-3 shadow-sm">
      <h2 class="font-semibold text-sm uppercase tracking-wide">IVA deducible — Operaciones interiores corrientes</h2>
    </div>
    <table class="w-full text-sm">
      <thead class="bg-brand-muted text-brand-navy/75 text-xs">
        <tr>
          <th class="px-4 py-2 text-left">Casilla</th>
          <th class="px-4 py-2 text-left">Descripción</th>
          <th class="px-4 py-2 text-right font-bold">Importe</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-mono text-brand-navy font-bold">28</td>
          <td class="px-4 py-3 text-gray-600">Base imponible</td>
          <td class="px-4 py-3 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_28] %></td>
        </tr>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-mono text-brand-navy font-bold">29</td>
          <td class="px-4 py-3 text-gray-600">Cuota</td>
          <td class="px-4 py-3 text-right font-medium"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_29] %></td>
        </tr>
        <tr class="bg-brand-muted/80 font-bold">
          <td class="px-4 py-3 font-mono text-brand-navy">45</td>
          <td class="px-4 py-3 text-brand-navy">Total a deducir (en la app: mismas compras que 28–29)</td>
          <td class="px-4 py-3 text-right text-brand-navy"><%= render "reports/modelo303_amount_cell", amount: @report[:casilla_45] %></td>
        </tr>
      </tbody>
    </table>

    <%# RESULTADO %>
    <div class="border-t-2 border-gray-200">
      <div class="px-4 py-3 bg-brand-muted/60 border-b border-gray-100">
        <p class="text-xs text-brand-navy/80">
          <span class="font-mono font-semibold">46</span> Resultado régimen general (27 − 45):
          <span class="font-mono tabular-nums font-medium text-gray-900"><%= number_to_currency(@report[:casilla_46], unit: "€", separator: ",", delimiter: ".") %></span>
        </p>
      </div>
      <div class="px-4 py-4 <%= @report[:casilla_64] >= 0 ? 'bg-red-50' : 'bg-green-50' %>">
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3">
          <div>
            <span class="font-mono font-bold text-lg <%= @report[:casilla_64] >= 0 ? 'text-red-700' : 'text-green-700' %>">64</span>
            <span class="ml-2 font-semibold text-gray-700">Resultado liquidación</span>
            <p class="text-xs text-gray-500 mt-1 max-w-md">Si solo declaras régimen general sin otros apartados, la 64 coincide con la 46. Revisa compensaciones y régimen simplificado en el programa de la AEAT.</p>
          </div>
          <div class="text-right">
            <div class="flex flex-wrap items-center justify-end gap-2">
              <p class="text-2xl font-bold tabular-nums <%= @report[:casilla_64] >= 0 ? 'text-red-600' : 'text-green-600' %>">
                <%= number_to_currency(@report[:casilla_64], unit: "€", separator: ",", delimiter: ".") %>
              </p>
              <%= render "shared/clipboard_copy_icon_button",
                    copy_value: modelo303_copy_value(@report[:casilla_64]),
                    title: "Copiar importe con formato español (miles con punto, decimales con coma)" %>
            </div>
            <p class="text-xs text-gray-500 mt-1"><%= @report[:casilla_64] >= 0 ? "A ingresar en Hacienda" : "A devolver / compensar" %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="mt-6 text-center">
  <%= link_to invoices_path(invoice_type: "emitida", year: @year, quarter: @quarter), class: "text-sm text-brand-navy hover:text-brand-teal hover:underline mr-4" do %>
    Ver facturas emitidas de este trimestre
  <% end %>
  <%= link_to invoices_path(invoice_type: "recibida", year: @year, quarter: @quarter), class: "text-sm text-brand-teal-dark hover:text-brand-navy hover:underline" do %>
    Ver facturas recibidas de este trimestre
  <% end %>
</div>
