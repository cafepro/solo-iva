<% content_for :title, "Dashboard — SoloIVA" %>

<div class="mb-6 flex flex-wrap items-center justify-end gap-2">
  <div class="flex flex-wrap gap-2">
    <% [Date.today.year, Date.today.year - 1].each do |y| %>
      <% [1, 2, 3, 4].each do |q| %>
        <%= link_to "#{y} T#{q}", dashboard_path(year: y, quarter: q),
            class: "text-xs px-2 py-1 rounded #{@year == y && @quarter == q ? 'bg-brand-teal text-white shadow-sm' : 'bg-white border border-gray-200 text-brand-navy/80 hover:bg-brand-muted hover:border-brand-navy/25'}" %>
      <% end %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="bg-white rounded-lg border p-5">
    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">IVA devengado <span class="text-gray-400 font-normal normal-case">(cas. 27)</span></p>
    <p class="text-2xl font-bold text-gray-900"><%= number_to_currency(@report[:casilla_27], unit: "€", separator: ",", delimiter: ".") %></p>
  </div>
  <div class="bg-white rounded-lg border p-5">
    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">IVA deducible <span class="text-gray-400 font-normal normal-case">(cas. 45)</span></p>
    <p class="text-2xl font-bold text-gray-900"><%= number_to_currency(@report[:casilla_45], unit: "€", separator: ",", delimiter: ".") %></p>
  </div>
  <div class="bg-white rounded-lg border p-5 <%= @report[:casilla_64] >= 0 ? 'border-red-200' : 'border-green-200' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Resultado <span class="text-gray-400 font-normal normal-case">(cas. 64)</span></p>
    <p class="text-2xl font-bold <%= @report[:casilla_64] >= 0 ? 'text-red-600' : 'text-green-600' %>">
      <%= number_to_currency(@report[:casilla_64], unit: "€", separator: ",", delimiter: ".") %>
      <span class="text-sm font-normal"><%= @report[:casilla_64] >= 0 ? "a ingresar" : "a devolver" %></span>
    </p>
  </div>
</div>

<div class="mb-8">
  <%= link_to modelo303_reports_path(year: @year, quarter: @quarter),
      class: "inline-block bg-brand-teal text-white px-4 py-2 rounded hover:bg-brand-teal-dark text-sm font-medium" do %>
    Ver Modelo 303 completo &rarr;
  <% end %>
  <%= link_to new_invoice_path, class: "inline-block ml-2 bg-white border border-brand-navy/25 text-brand-navy px-4 py-2 rounded hover:bg-brand-muted text-sm font-medium" do %>
    + Nueva factura
  <% end %>
</div>

<%# Solo mostramos el aviso de Drive si aún no han conectado OAuth; la configuración sigue en el menú. %>
<% if current_user.google_drive_refresh_token.blank? %>
  <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <p class="text-sm font-semibold text-gray-800">Copia en Google Drive</p>
      <p class="text-xs text-gray-500 mt-1">
        Las recibidas pueden copiarse a Drive (Facturas → Recibidas → año → mes). Con subida desde «Subir facturas» se guarda el archivo original; si no, un PDF resumen.
      </p>
    </div>
    <div class="flex flex-wrap gap-2 shrink-0">
      <span class="text-xs text-amber-700 self-center">Sin conectar</span>
      <%= link_to "Configurar Google Drive", google_drive_settings_path,
          class: "inline-flex items-center px-3 py-1.5 rounded bg-gray-800 text-white text-sm font-medium hover:bg-gray-900" %>
    </div>
  </div>
<% end %>

<% if @recent_invoices.any? %>
  <h2 class="text-lg font-semibold text-gray-700 mb-3">Últimas facturas</h2>
  <div class="bg-white rounded-lg border overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
        <tr>
          <th class="px-4 py-3 text-left">Número</th>
          <th class="px-4 py-3 text-left">Fecha</th>
          <th class="px-4 py-3 text-left">Tipo</th>
          <th class="px-4 py-3 text-left">Emisor/Proveedor</th>
          <th class="px-4 py-3 text-right">Base</th>
          <th class="px-4 py-3 text-right">IVA</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @recent_invoices.each do |inv| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3"><%= link_to inv.invoice_number, edit_invoice_path(inv), class: "text-brand-navy hover:text-brand-teal hover:underline" %></td>
            <td class="px-4 py-3 text-gray-500"><%= inv.invoice_date&.strftime("%d/%m/%Y") %></td>
            <td class="px-4 py-3">
              <span class="px-2 py-0.5 rounded-full text-xs <%= inv.emitida? ? 'bg-brand-muted text-brand-navy' : 'bg-brand-teal-muted text-brand-teal-dark' %>">
                <%= inv.emitida? ? "Emitida" : "Recibida" %>
              </span>
            </td>
            <td class="px-4 py-3 text-gray-600"><%= inv.emitida? ? inv.recipient_name : inv.issuer_name %></td>
            <td class="px-4 py-3 text-right"><%= number_to_currency(inv.total_base, unit: "€", separator: ",", delimiter: ".") %></td>
            <td class="px-4 py-3 text-right"><%= number_to_currency(inv.total_iva, unit: "€", separator: ",", delimiter: ".") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
