<% content_for :title, "Google Drive — SoloIVA" %>

<div class="mb-6">
  <p class="text-sm text-gray-500">
    Las facturas <strong>recibidas</strong> y <strong>emitidas</strong> confirmadas se guardan bajo
    <span class="font-mono text-gray-700">Mi unidad → [carpeta 1] → [subcarpeta] → año → mes</span>.
    Recibidas por defecto: <span class="font-mono">Facturas → Recibidas</span>.
    Emitidas: <span class="font-mono">Facturas → Emitidas</span> (misma carpeta raíz, otra subcarpeta).
  </p>
  <p class="text-sm text-gray-600 mt-2">
    <strong>Recibidas:</strong> si vienen del flujo de <strong>Revisión</strong>, se sube el archivo original (PDF o imagen); si no, un PDF de resumen generado por la app.
    <strong>Emitidas:</strong> siempre el PDF de factura generado por SoloIVA (el mismo que descargas).
  </p>
</div>

<div class="bg-white rounded-lg border p-6 space-y-6">
  <div>
    <h2 class="text-sm font-semibold text-gray-700 mb-2">Estado</h2>
    <% if current_user.google_drive_refresh_token.present? %>
      <p class="text-green-700 text-sm">Cuenta de Google conectada.</p>
    <% else %>
      <p class="text-gray-600 text-sm">No conectado. Necesitas autorizar acceso solo a archivos que cree esta aplicación.</p>
    <% end %>
  </div>

  <div class="flex flex-wrap gap-3">
    <% if current_user.google_drive_refresh_token.blank? %>
      <%= link_to "Conectar con Google", authorize_google_drive_settings_path,
          class: "inline-flex items-center px-4 py-2 rounded bg-brand-teal text-white text-sm font-medium hover:bg-brand-teal-dark" %>
    <% else %>
      <%= button_to "Desconectar", disconnect_google_drive_settings_path, method: :delete,
          form: { data: { turbo_confirm: "¿Dejar de subir facturas a Drive?" } },
          class: "inline-flex items-center px-4 py-2 rounded border border-brand-navy/25 text-sm text-brand-navy hover:bg-brand-muted" %>
    <% end %>
  </div>

  <%= form_with model: current_user, url: google_drive_settings_path, method: :patch, class: "space-y-4 border-t pt-6" do |f| %>
    <h2 class="text-sm font-semibold text-gray-700">Carpetas en Drive</h2>
    <p class="text-xs text-gray-500">Usa <strong>dos niveles</strong> (no pongas «Facturas/Recibidas» en un solo campo: serían dos carpetas anidadas).</p>
    <div>
      <%= f.label :google_drive_folder_name, "Primera carpeta (bajo Mi unidad)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :google_drive_folder_name,
          placeholder: "Facturas",
          class: "w-full max-w-md border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :google_drive_received_folder_name, "Subcarpeta para facturas recibidas", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :google_drive_received_folder_name,
          placeholder: "Recibidas",
          class: "w-full max-w-md border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :google_drive_issued_folder_name, "Subcarpeta para facturas emitidas", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :google_drive_issued_folder_name,
          placeholder: "Emitidas",
          class: "w-full max-w-md border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
    <div class="flex items-center gap-2">
      <%= f.check_box :google_drive_sync_enabled, class: "rounded border-gray-300" %>
      <%= f.label :google_drive_sync_enabled, "Subir facturas a Drive automáticamente (recibidas y emitidas)", class: "text-sm text-gray-700" %>
    </div>
    <div>
      <%= f.submit "Guardar preferencias", class: "px-4 py-2 rounded bg-gray-800 text-white text-sm font-medium hover:bg-gray-900 cursor-pointer" %>
    </div>
  <% end %>
</div>

<div class="mt-6 text-sm text-gray-500">
  <p>Configuración técnica: credenciales OAuth en <code class="text-xs bg-gray-100 px-1 rounded">google_oauth</code> (client_id, client_secret) y tipo de aplicación «Web» con redirección a
    <code class="text-xs bg-gray-100 px-1 rounded"><%= callback_google_drive_settings_url %></code>.
  </p>
</div>
